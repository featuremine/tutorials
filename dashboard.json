          "format": "table",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT (info->'orderType'->'limit')::text as price, (info->'quantity')::text as quantity, (info->'orderSide')::text as side, strategy, oms, strgordid, pubtime, seqnum, type, pubseq, imnts.name as imnt, venues.name as venue from order_events\nINNER JOIN imnts ON order_events.type = 'new' AND (order_events.info->'securityId')::text = imnts.imnt_id::text AND imnts.name = '$instrument'\nINNER JOIN venues ON (order_events.info->'venueID')::text = venues.venue_id::text AND venues.name = '$market'\nUNION\nSELECT NULL as price, (info->'leaves')::text as quantity, NULL as side, strategy, oms, strgordid, pubtime, seqnum, type, pubseq, imnts.name as imnt, venues.name as venue from order_events\nINNER JOIN imnts ON order_events.type = 'cancel' AND (order_events.info->'securityId')::text = imnts.imnt_id::text AND imnts.name = '$instrument'\nINNER JOIN venues ON (order_events.info->'venueID')::text = venues.venue_id::text AND venues.name = '$market'\nUNION\nSELECT NULL as price, NULL as quantity, NULL as side, strategy, oms, strgordid, pubtime, seqnum, type, pubseq, NULL as imnt, NULL as venue from order_events\nWHERE NOT (type = 'new' OR type = 'cancel')\nORDER BY pubseq ASC;",
          "refId": "A",
          "select": [
